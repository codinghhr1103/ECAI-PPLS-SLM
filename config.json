{
  "model": {
    "p": 20,
    "q": 20,
    "r": 3,
    "n_samples": 500
  },
  "data_generation": {
    "noise_levels": {
      "low": {
        "sigma_e2": 0.1,
        "sigma_f2": 0.1,
        "sigma_h2": 0.05
      },
      "high": {
        "sigma_e2": 0.5,
        "sigma_f2": 0.5,
        "sigma_h2": 0.25
      }
    },
    "sine_parameters": {
      "frequency": 0.7,
      "magnitude": 0.7
    }
  },
  "algorithms": {
    "common": {
      "n_starts": 8,
      "random_seed": 42
    },
    "slm": {
      "optimizer": "trust-constr",
      "max_iter": 2000,
      "use_noise_preestimation": true,
      "gtol": 0.005,
      "xtol": 0.005,
      "barrier_tol": 0.005,
      "constraint_slack": 0.005
    },
    "em": {
      "max_iter": 2000,
      "tolerance": 0.005
    },
    "ecm": {
      "max_iter": 2000,
      "tolerance": 0.005
    }
  },
  "experiment": {
    "n_trials": 20,
    "random_seed": 42,
    "parallel_trials": true,
    "n_jobs": 8
  },
  "output": {
    "save_intermediate": true,
    "base_dir": "C:/Users/ASUS/Desktop/ECAI-PPLS-SLM/output",
    "figure_format": "png",
    "force_data_generation": true,
    "force_parameter_estimation": true,
    "force_visualization": true
  },
  "analysis": {
    "compute_bias_variance": true,
    "recovery_threshold": 0.1,
    "confidence_level": 0.95
  },
  "experiments": {
    "run": {
      "montecarlo": true,
      "speed": true,
      "association": true,
      "prediction": true,
      "brca_prediction": false,
      "brca_calibration": false,
      "sync_artifacts": true
    },
    "association": {
      "brca_data": "application/brca_data_w_subtypes.csv.zip",
      "output_dir": "results_association"
    },
    "prediction": {
      "thread_limit": 1,
      "output_dir": "results_prediction",
      "p": 100,
      "q": 100,
      "r": 20,
      "n_samples": 120,
      "n_folds": 5,
      "n_starts": 8,
      "seed": 42,
      "sigma_e2": 0.1,
      "sigma_f2": 0.1,
      "sigma_h2": 0.05,
      "max_iter": 1000,
      "em_tol": 1e-4,
      "plot": true,
      "no_baselines": false,

      "parallel_folds": true,
      "fold_workers": 5,

      "slm_optimizer": "trust-constr",
      "slm_gtol": 0.005,
      "slm_xtol": 0.005,
      "slm_barrier_tol": 0.005,
      "slm_constraint_slack": 0.005,
      "slm_progress_every": 1,
      "slm_early_stop_patience": 2,
      "slm_early_stop_rel_improvement": 0.001,
      "slm_data_start": true,
      "slm_verbose": true,
      "cv_heartbeat_sec": 30


    },
    "prediction_brca": {
      "thread_limit": 1,
      "brca_data": "application/brca_data_w_subtypes.csv.zip",
      "output_dir": "results_prediction_brca",
      "seed": 42,
      "n_folds": 5,
      "r_grid": "3,5,8,10",
      "n_starts": 8,
      "max_iter": 1000,
      "em_tol": 1e-4
    },
    "calibration_brca": {
      "thread_limit": 1,
      "brca_data": "application/brca_data_w_subtypes.csv.zip",
      "output_dir": "results_prediction_brca",
      "prediction_summary": "results_prediction_brca/brca_prediction_summary.csv",
      "seed": 42,
      "n_folds": 5,
      "r": null,
      "n_starts": 8,
      "max_iter": 1000
    }
  }
}

